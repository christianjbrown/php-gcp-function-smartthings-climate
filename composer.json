{
    "require": {
        "php": "~8.3",
        "christianjbrown/php-cloud-function-lib": "dev-main",
        "christianjbrown/php-smartthings-api-lib": "dev-main",
        "christianjbrown/php-user-friendly-exception-lib": "dev-main",
        "google/cloud-functions-framework": "^1.1",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0.8",
        "christianjbrown/php-code-quality-scripts": "dev-main",
        "phpstan/phpstan": "^2.0"
    },
    "config": {
        "bin-dir": "bin"
    },
    "scripts": {
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "clear && (export $(grep -v '^#' .local.env | xargs) && FUNCTION_SOURCE=index.php FUNCTION_TARGET=run FUNCTION_SIGNATURE_TYPE=http php -S localhost:${PORT:-8080} ./vendor/bin/router.php)"
        ],
        "test": [
            "clear && XDEBUG_MODE=coverage ./bin/phpunit --process-isolation && open ./.phpunit.cache/code-coverage-html/index.html"
        ],
        "stan": [
            "clear && ./bin/phpstan analyse"
        ],
        "check-style": [
            "clear && ./bin/php-cs ./src ./tests"
        ],
        "check-style-diff": [
            "clear && ./bin/php-cs-diff"
        ],
        "fix-style": [
            "clear && ./bin/php-cs-fix ./src ./tests"
        ],
        "fix-style-diff": [
            "clear && ./bin/php-cs-fix-diff"
        ]
    },
    "autoload": {
        "psr-4": {
            "ChristianBrown\\GetSmartHomeTemps\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChristianBrown\\GetSmartHomeTemps\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-cloud-function-lib.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-user-friendly-exception-lib.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-api-client-lib.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-code-quality-scripts.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-smartthings-api-lib.git"
        }
    ],
    "minimum-stability": "dev"
}
