{
    "require": {
        "php": "~8.2",
        "christianjbrown/cloud-function": "dev-main",
        "christianjbrown/user-friendly-exception": "dev-main",
        "google/cloud-functions-framework": "^1.1",
        "psr/http-client": "^1.0"
    },
    "minimum-stability": "dev",
    "scripts": {
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "(export $(grep -v '^#' .local.env | xargs) && FUNCTION_SOURCE=index.php FUNCTION_TARGET=run FUNCTION_SIGNATURE_TYPE=http php -S localhost:${PORT:-8080} vendor/bin/router.php)"
        ],
        "test": [
            "./vendor/bin/phpunit && open ./.phpunit.cache/code-coverage-html/index.html"
        ],
        "fix": [
            "./vendor/bin/php-cs-fixer fix ./src ./tests -vvv --config=vendor/christianjbrown/php-cs-fixer-wrapper/rule-sets/risky.php"
        ],
        "fix-test": [
            "@fix",
            "@test"
        ]
    },
    "autoload": {
        "psr-4": {
            "": "src/"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/cloud-function.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/user-friendly-exception.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/json-api-client.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-cs-fixer-wrapper.git"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.0@dev",
        "christianjbrown/php-cs-fixer-wrapper": "dev-main"
    }
}
